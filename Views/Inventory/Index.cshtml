
@model List<InventoryEnterpriseProject.Core.Entities.InventoryItem>

@{
    ViewData["Title"] = "Inventory";
}

<!-- Stats Overview -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center text-2xl">
                <i class="ph ph-clipboard-text"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-1">Total Products</p>
                <div class="flex items-baseline gap-2">
                    <h3 class="text-2xl font-bold text-slate-800">@Model.Count()</h3>
                    <span class="text-[11px] font-semibold text-emerald-500 bg-emerald-50 px-1.5 py-0.5 rounded-md flex items-center gap-1">
                        <i class="ph-bold ph-trend-up"></i> +2.5% this month
                    </span>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-red-50 text-red-500 flex items-center justify-center text-2xl">
                <i class="ph-fill ph-warning"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-1">Low Stock Alert</p>
                <div class="flex items-baseline gap-2">
                    <h3 class="text-2xl font-bold text-slate-800">@Model.Count(x => x.Quantity < 10)</h3>
                </div>
                <p class="text-[11px] text-slate-400 font-medium mt-1">Requires immediate attention</p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm flex items-center justify-between">
        <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center text-2xl">
                <i class="ph-fill ph-money"></i>
            </div>
            <div>
                <p class="text-xs font-semibold text-slate-400 tracking-wider uppercase mb-1">Total Inventory Value</p>
                <div class="flex items-baseline gap-2">
                    <h3 class="text-2xl font-bold text-slate-800">@Model.Sum(x => x.Price * x.Quantity).ToString("C")</h3>
                    <span class="text-[11px] font-semibold text-emerald-500 bg-emerald-50 px-1.5 py-0.5 rounded-md flex items-center gap-1">
                        <i class="ph-bold ph-trend-up"></i> +12% from Q3
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Page Header & Filters -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-6">
    <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-1 tracking-tight">Product Inventory</h2>
        <p class="text-slate-500 text-sm">Manage and track your warehouse stock levels across all categories.</p>
    </div>
    <div class="flex items-center gap-3">
        <button class="px-4 py-2 bg-white border border-slate-200 text-slate-600 font-medium text-sm rounded-lg hover:bg-slate-50 transition-colors flex items-center gap-2">
            <i class="ph ph-export"></i>
            Export
        </button>
        <a href="/Inventory/Create" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm rounded-lg shadow-[0_4px_14px_0_rgba(30,81,255,0.39)] transition-colors flex items-center gap-2">
            <i class="ph-bold ph-plus"></i> Add New Product
        </a>
    </div>
</div>

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div class="flex flex-wrap gap-2">
        <button class="px-4 py-1.5 bg-blue-600 text-white text-sm font-medium rounded-full shadow-sm">All Products</button>
        <button class="px-4 py-1.5 bg-white border border-slate-200 text-slate-600 text-sm font-medium rounded-full hover:bg-slate-50 transition-colors">Electronics</button>
        <button class="px-4 py-1.5 bg-white border border-slate-200 text-slate-600 text-sm font-medium rounded-full hover:bg-slate-50 transition-colors">Furniture</button>
        <button class="px-4 py-1.5 bg-white border border-slate-200 text-slate-600 text-sm font-medium rounded-full hover:bg-slate-50 transition-colors">Office Supplies</button>
        <button class="px-4 py-1.5 bg-white border border-slate-200 text-slate-600 text-sm font-medium rounded-full hover:bg-slate-50 transition-colors">Accessories</button>
    </div>
    <button class="text-slate-500 text-sm font-medium hover:text-slate-800 transition-colors flex items-center gap-2">
        <i class="ph ph-sliders-horizontal"></i>
        More Filters
    </button>
</div>

<!-- Table -->
<div class="bg-white border text-sm border-slate-200 rounded-xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-slate-50/50 border-b border-slate-200 text-[11px] uppercase tracking-wider text-slate-400 font-semibold">
                    <th class="px-6 py-4">Product</th>
                    <th class="px-6 py-4">SKU</th>
                    <th class="px-6 py-4">Category</th>
                    <th class="px-6 py-4">Stock Level</th>
                    <th class="px-6 py-4">Price</th>
                    <th class="px-6 py-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach(var item in Model)
                {
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center text-slate-400 border border-slate-200 shrink-0">
                                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                        <path fill-rule="evenodd" d="M1.5 6a2.25 2.25 0 0 1 2.25-2.25h16.5A2.25 2.25 0 0 1 22.5 6v12a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 18V6ZM3 16.06V18c0 .414.336.75.75.75h16.5A.75.75 0 0 0 21 18v-1.94l-2.69-2.689a1.5 1.5 0 0 0-2.12 0l-.88.879.97.97a.75.75 0 1 1-1.06 1.06l-5.16-5.159a1.5 1.5 0 0 0-2.12 0L3 16.061Zm10.125-7.81a1.125 1.125 0 1 1 2.25 0 1.125 1.125 0 0 1-2.25 0Z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                                <div class="max-w-[200px]">
                                    <h4 class="text-slate-800 font-semibold truncate leading-tight mb-0.5">@item.Name</h4>
                                    <p class="text-[11px] text-slate-500 truncate">Standard Inventory</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-slate-500 font-medium">@(string.IsNullOrEmpty(item.SKU) ? "N/A" : item.SKU)</td>
                        <td class="px-6 py-4 text-slate-500 font-medium">@(string.IsNullOrEmpty(item.Category) ? "Uncategorized" : item.Category)</td>
                        <td class="px-6 py-4">
                            @if(item.Quantity > 10)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-600 border border-emerald-100">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                    In Stock (@item.Quantity)
                                </span>
                            }
                            else if(item.Quantity > 0)
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-600 border border-amber-100">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                    Low Stock (@item.Quantity)
                                </span>
                            }
                            else
                            {
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-red-50 text-red-600 border border-red-100">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                                    Out of Stock (0)
                                </span>
                            }
                        </td>
                        <td class="px-6 py-4 text-slate-800 font-bold whitespace-nowrap">@item.Price.ToString("C")</td>
                        <td class="px-6 py-4">
                            <div class="flex items-center justify-center gap-3">
                                <a href="/Inventory/Edit/@item.Id" class="text-blue-600 hover:text-blue-800 transition-colors p-1" title="Edit">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                        <path d="M21.731 2.269a2.625 2.625 0 0 0-3.712 0l-1.157 1.158 3.712 3.712 1.157-1.157a2.625 2.625 0 0 0 0-3.713ZM19.5 7.125 16.875 4.5l-10.875 10.875v2.625h2.625L19.5 7.125Z" />
                                    </svg>
                                </a>
                                <form method="post" action="/Inventory/Delete/@item.Id" onsubmit="return confirm('Are you sure?');">
                                    <button type="submit" class="text-red-500 hover:text-red-700 transition-colors p-1" title="Delete">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                                            <path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 1 3.273 0C14.39 3.05 15 3.684 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.794.609-1.428 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                
                @if(!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-6 py-12 text-center text-slate-500">
                            <i class="ph ph-package text-4xl mb-3 text-slate-300 mx-auto block"></i>
                            <p class="font-medium text-slate-600">No products found</p>
                            <p class="text-sm mt-1">Get started by adding a new product to your inventory.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if(Model.Any())
    {
    <div class="px-4 sm:px-6 py-4 border-t border-slate-200 bg-slate-50 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
        <p>Showing 1 to @Model.Count() of @Model.Count() entries</p>
        <div class="flex items-center gap-1">
            <button class="px-3 py-1.5 border border-slate-200 bg-white rounded-md hover:bg-slate-50 transition-colors text-slate-600 font-medium disabled:opacity-50">Previous</button>
            <button class="px-3 py-1.5 border border-blue-600 bg-blue-600 rounded-md text-white font-medium">1</button>
            <button class="px-3 py-1.5 border border-slate-200 bg-white rounded-md hover:bg-slate-50 transition-colors text-slate-600 font-medium">Next</button>
        </div>
    </div>
    }
</div>
