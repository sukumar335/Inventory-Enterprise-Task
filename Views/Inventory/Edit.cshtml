@model InventoryEnterpriseProject.Core.Entities.InventoryItem

@{
    ViewData["Title"] = "Edit Product";
}

<div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-3 mb-6">
        <a href="/Inventory" class="w-8 h-8 flex items-center justify-center rounded-md bg-white border border-slate-200 text-slate-500 hover:text-slate-800 hover:bg-slate-50 transition-colors">
            <i class="ph-bold ph-arrow-left"></i>
        </a>
        <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Edit @Model.Name</h2>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <form method="post" class="p-6 md:p-8">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <!-- Name -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Product Name <span class="text-red-500">*</span></label>
                    <input type="text" name="Name" required value="@Model.Name" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all text-slate-700">
                </div>

                <!-- SKU -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">SKU</label>
                    <input type="text" name="SKU" value="@Model.SKU" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all text-slate-700">
                </div>

                <!-- Category -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Category</label>
                    <input type="text" name="Category" value="@Model.Category" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all text-slate-700">
                </div>

                <!-- Price -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Unit Price (₹)</label>
                    <div class="relative">
                        <i class="ph ph-currency-inr absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-base"></i>
                        <input type="number" step="0.01" name="Price" value="@Model.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-9 pr-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all text-slate-700">
                    </div>
                </div>

                <!-- Quantity -->
                <div>
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Stock Level</label>
                    <input type="number" name="Quantity" value="@Model.Quantity" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:ring-2 focus:ring-blue-100 focus:border-blue-400 outline-none transition-all text-slate-700">
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100 flex items-center justify-end gap-3">
                <a href="/Inventory" class="px-5 py-2.5 text-sm font-medium text-slate-600 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">Cancel</a>
                <button type="submit" class="px-5 py-2.5 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-[0_4px_14px_0_rgba(30,81,255,0.39)] transition-colors flex items-center gap-2">
                    <i class="ph-bold ph-check"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
