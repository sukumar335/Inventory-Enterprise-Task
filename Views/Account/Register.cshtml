@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - StockMaster</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; background-color: #f9fbfb; }</style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl border border-slate-100 p-8">
        <div class="flex items-center justify-center mb-8">
            <div class="bg-indigo-600 w-12 h-12 rounded-xl flex items-center justify-center text-white mr-3">
                <i class="ph-fill ph-user-plus text-3xl"></i>
            </div>
            <div>
                <h1 class="font-bold text-2xl leading-tight text-slate-800">StockMaster</h1>
                <p class="text-xs text-slate-500 font-medium tracking-wide">Create an Account</p>
            </div>
        </div>

        @if(ViewBag.Error != null)
        {
            <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-600 text-sm rounded-lg flex items-center gap-3 font-medium">
                <i class="ph-fill ph-warning-circle text-lg"></i>
                @ViewBag.Error
            </div>
        }

        <form method="post" id="registerForm">
            <div class="mb-5">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Username</label>
                <div class="relative">
                    <i class="ph ph-user absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                    <input type="text" id="regUser" name="username" placeholder="Choose a username" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                </div>
                <p id="regUserErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">Username is required.</p>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Email Address</label>
                <div class="relative">
                    <i class="ph ph-envelope absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                    <input type="email" id="regEmail" name="email" placeholder="you@company.com" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                </div>
                <p id="regEmailErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">Valid email is required.</p>
            </div>

            <div class="flex gap-4 mb-5">
                <div class="flex-1">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">First Name</label>
                    <div class="relative">
                        <i class="ph ph-identification-card absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                        <input type="text" id="regFirst" name="firstName" placeholder="First name" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                    </div>
                    <p id="regFirstErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">First name required.</p>
                </div>
                <div class="flex-1">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">Last Name</label>
                    <div class="relative">
                        <i class="ph ph-identification-card absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                        <input type="text" id="regLast" name="lastName" placeholder="Last name" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                    </div>
                    <p id="regLastErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">Last name required.</p>
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Password</label>
                <div class="relative">
                    <i class="ph ph-lock-key absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                    <input type="password" id="regPass" name="password" placeholder="Choose a secure password" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                </div>
                <p id="regPassErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">Password minimum 6 chars.</p>
            </div>

            <div class="mb-6">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Confirm Password</label>
                <div class="relative">
                    <i class="ph ph-lock-key absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg"></i>
                    <input type="password" id="regConfirm" name="confirmPassword" placeholder="Confirm your password" class="w-full bg-slate-50 border border-slate-200 rounded-lg pl-10 pr-4 py-3 text-sm focus:ring-2 focus:ring-indigo-100 focus:border-indigo-400 outline-none transition-all placeholder-slate-400 text-slate-700">
                </div>
                <p id="regConfirmErr" class="text-red-500 text-xs mt-1.5 font-medium hidden">Passwords do not match.</p>
            </div>

            <button type="submit" id="regBtn" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg shadow-[0_4px_14px_0_rgba(79,70,229,0.39)] transition-colors flex items-center justify-center gap-2">
                Create Account <i class="ph-bold ph-check-circle"></i>
            </button>
        </form>

        <script>
            const rForm = document.getElementById('registerForm');
            const rUsr = document.getElementById('regUser'), rUsrE = document.getElementById('regUserErr');
            const rEm = document.getElementById('regEmail'), rEmE = document.getElementById('regEmailErr');
            const rFn = document.getElementById('regFirst'), rFnE = document.getElementById('regFirstErr');
            const rLn = document.getElementById('regLast'), rLnE = document.getElementById('regLastErr');
            const rPw = document.getElementById('regPass'), rPwE = document.getElementById('regPassErr');
            const rCp = document.getElementById('regConfirm'), rCpE = document.getElementById('regConfirmErr');

            function valEmpty(inp, err) {
                if (inp.value.trim() === '') { showErr(inp, err); return false; }
                hideErr(inp, err); return true;
            }
            function valLen(inp, err, len) {
                if (inp.value.length < len) { showErr(inp, err); return false; }
                hideErr(inp, err); return true;
            }
            function valMatch(inp, err, matchVal) {
                if (inp.value !== matchVal) { showErr(inp, err); return false; }
                hideErr(inp, err); return true;
            }
            function valEmail(inp, err) {
                if (!inp.value.includes('@@') || !inp.value.includes('.')) { showErr(inp, err); return false; }
                hideErr(inp, err); return true;
            }

            function showErr(inp, err) {
                err.classList.remove('hidden');
                inp.classList.add('border-red-400', 'bg-red-50');
            }
            function hideErr(inp, err) {
                err.classList.add('hidden');
                inp.classList.remove('border-red-400', 'bg-red-50');
            }

            rUsr.addEventListener('input', () => valEmpty(rUsr, rUsrE));
            rEm.addEventListener('input', () => valEmail(rEm, rEmE));
            rFn.addEventListener('input', () => valEmpty(rFn, rFnE));
            rLn.addEventListener('input', () => valEmpty(rLn, rLnE));
            rPw.addEventListener('input', () => { valLen(rPw, rPwE, 6); if(rCp.value) valMatch(rCp, rCpE, rPw.value); });
            rCp.addEventListener('input', () => valMatch(rCp, rCpE, rPw.value));

            rForm.addEventListener('submit', (e) => {
                let isValid = valEmpty(rUsr, rUsrE) 
                            & valEmail(rEm, rEmE) 
                            & valEmpty(rFn, rFnE) 
                            & valEmpty(rLn, rLnE) 
                            & valLen(rPw, rPwE, 6) 
                            & valMatch(rCp, rCpE, rPw.value);
                
                if (!isValid) e.preventDefault();
            });
        </script>

        <p class="text-center text-slate-500 text-sm mt-8">
            Already have an account? <a href="/Account/Login" class="text-indigo-600 font-semibold hover:underline">Sign in here</a>
        </p>
    </div>

</body>
</html>
